<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <data noupdate="1">

        <record id="category_mbt" model="ir.module.category">
            <field name="name">Multi-Branch Transfer</field>
            <field name="sequence">25</field>
        </record>

        <record id="privilege_mbt" model="res.groups.privilege">
            <field name="name">Multi-Branch Transfer</field>
            <field name="category_id" ref="category_mbt"/>
        </record>

        <record id="group_mbt_user" model="res.groups">
            <field name="name">User</field>
            <field name="privilege_id" ref="privilege_mbt"/>
            <field name="implied_ids" eval="[(4, ref('stock.group_stock_user'))]"/>
            <field name="comment">User can create and process Multi-Branch Transfer requests.</field>
        </record>

        <record id="group_mbt_manager" model="res.groups">
            <field name="name">Manager</field>
            <field name="privilege_id" ref="privilege_mbt"/>
            <field name="implied_ids" eval="[(4, ref('group_mbt_user')), (4, ref('stock.group_stock_manager'))]"/>
            <field name="comment">Manager can reset and delete Multi-Branch Transfer requests.</field>
        </record>

        <record id="rule_mbt_request_company" model="ir.rule">
            <field name="name">Multi-Branch Transfer: multi-company</field>
            <field name="model_id" ref="model_mbt_request"/>
            <field name="domain_force">[('company_id', 'in', company_ids)]</field>
            <field name="groups" eval="[(4, ref('group_mbt_user'))]"/>
        </record>

        <record id="rule_mbt_request_line_company" model="ir.rule">
            <field name="name">Multi-Branch Transfer Line: multi-company</field>
            <field name="model_id" ref="model_mbt_request_line"/>
            <field name="domain_force">[('request_id.company_id', 'in', company_ids)]</field>
            <field name="groups" eval="[(4, ref('group_mbt_user'))]"/>
        </record>

    </data>
</odoo>